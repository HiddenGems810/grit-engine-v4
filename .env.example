# FORMAT runs local-first for editing, portrait analysis, effects, and export.
# These public variables only configure launch CTAs. Do not put secrets here.

# External checkout or payment page for production access.
NEXT_PUBLIC_FORMAT_PAYMENT_URL=

# External paid-beta, waitlist, or private access page.
NEXT_PUBLIC_FORMAT_BETA_URL=

# Optional support/contact fallback used when no payment or beta URL is set.
NEXT_PUBLIC_FORMAT_SUPPORT_EMAIL=
